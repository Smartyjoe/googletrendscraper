# ============================================================================
# Python PyTrends API - .gitignore
# ============================================================================

# ============================================================================
# Python Environment
# ============================================================================

# Virtual Environment
venv/
env/
ENV/
.venv/
virtualenv/

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / Packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

