# ============================================================================
# cPanel Specific
# ============================================================================

# Passenger restart file
tmp/restart.txt

# cPanel temp files
.cpanel/
.htpasswds/
.lastlogin
.trash/

# cPanel error documents (keep custom ones, ignore defaults)
# error_docs/

# ============================================================================
# Database Files
# ============================================================================

# SQLite
*.db
*.sqlite
*.sqlite3

# Redis dumps
dump.rdb

# ============================================================================
# Backup Files
# ============================================================================

# Backup files
*.bak
*.backup
*.old
*_backup
*_old
backup/

# Old implementation (already created)
pytrends_api_old.py

# ============================================================================
# Documentation (Optional - uncomment if you don't want to track docs)
# ============================================================================

# Uncomment these if you don't want documentation in Git
# *.md
# !README.md

# ============================================================================
# Large Files & Data
# ============================================================================

# Data files
*.csv
*.json
*.xml
data/
datasets/

# Exclude large files (>100MB)
*.zip
*.tar.gz
*.rar
*.7z

# ============================================================================
# Security & Configuration (Production-specific)
# ============================================================================

# Production configuration (DO NOT COMMIT)
config.production.py
settings.production.py

# SSL Certificates (never commit these!)
*.crt
*.ca-bundle
ssl/

# ============================================================================
# Deployment Files (Keep local only)
# ============================================================================

# Deployment scripts (optional - uncomment if you don't want to share)
# deploy.sh
# deploy.ps1

# Local deployment config
deployment.local.yml
deploy.local.json

# ============================================================================
# Test & Development Only Files
# ============================================================================

# Temporary test scripts
tmp_rovodev_*
test_*.tmp
scratch.py
playground.py

# ============================================================================
# Node Modules (if you add any frontend tools)
# ============================================================================

# node_modules/
# package-lock.json
# yarn.lock

# ============================================================================
# Notes
# ============================================================================

# This .gitignore is configured for a Python FastAPI application
# deployed on cPanel with Passenger.
#
# IMPORTANT FILES TO KEEP IN GIT:
# - pytrends_api.py (main application)
# - cache_manager.py (caching logic)
# - requirements.txt (dependencies)
# - passenger_wsgi.py (cPanel deployment)
# - htaccess (Apache config)
# - README.md (documentation)
# - DEPLOYMENT.md (deployment guide)
#
# NEVER COMMIT:
# - .env files with secret keys
# - Log files
# - Virtual environment (venv/)
# - Cache directories
# - SSL certificates
# - Production configuration with secrets
